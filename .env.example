# Copy this file to ".env" and adjust to your local setup:
#   cp .env.example .env
#
# .env is for LOCAL development only and must never be committed (see .gitignore).
# In production, your hosting platform injects these values for you.

PORT=3000

# Connection string format: postgres://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=postgres://postgres:postgres@localhost:5432/bookshelf

NODE_ENV=development

# Secret used to SIGN and VERIFY login tokens (JWTs). CHANGE THIS to a long,
# random value — anyone who knows it can forge a valid login.
JWT_SECRET=dev-jwt-secret-change-me-to-something-long-and-random

# Logging verbosity: fatal | error | warn | info | debug | trace | silent
LOG_LEVEL=info

# Which browser origin may call the API. "*" allows any (fine for local dev).
CORS_ORIGIN=*

# Max requests allowed per IP per minute before a 429 response.
RATE_LIMIT_MAX=100
