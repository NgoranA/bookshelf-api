# Settings used ONLY when running tests (npm test loads this file).
# It points at a SEPARATE database so tests never touch your real/dev data.
# This file contains no real secrets, so it is safe to commit.

PORT=3001
DATABASE_URL=postgres://postgres:postgres@localhost:5432/bookshelf_test
NODE_ENV=test
JWT_SECRET=test-jwt-secret
LOG_LEVEL=silent
CORS_ORIGIN=*
RATE_LIMIT_MAX=10000
